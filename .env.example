# Copy to .env and fill in. NEVER commit .env.

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://uap:uap@localhost:5432/uap_archive

# --- Anthropic (summaries + structured extraction only; NOT embeddings) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Embeddings: local, free (bge-small-en-v1.5 -> 384 dims) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Paths ---
DATA_DIR=./data

# --- OCR ---
OCR_CONF_THRESHOLD=60
OCR_DPI=200

# --- Chunking ---
CHUNK_TOKENS=500
CHUNK_OVERLAP=50

# --- Cost guard (hard budget for a full ingestion run, USD) ---
COST_BUDGET_USD=25
PRICE_IN_PER_MTOK=0.80
PRICE_OUT_PER_MTOK=4.00

# --- Source ---
SOURCE_COLLECTION=project-blue-book

# --- API CORS (frontend origin) ---
CORS_ORIGINS=*
